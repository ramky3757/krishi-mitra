{
  "name": "harvestbond",
  "private": true,
  "version": "1.0.0",
  "description": "HarvestBond — Know your farmer. Own your harvest.",
  "packageManager": "pnpm@11.2.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "pnpm --filter @harvestbond/mobile start",
    "mobile:android": "pnpm --filter @harvestbond/mobile android",
    "mobile:ios": "pnpm --filter @harvestbond/mobile ios",
    "mobile:web": "pnpm --filter @harvestbond/mobile web",
    "admin": "pnpm --filter @harvestbond/admin dev",
    "admin:build": "pnpm --filter @harvestbond/admin build",
    "db:migrate": "supabase db push"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
